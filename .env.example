# Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
ELASTIC_HOST=localhost
ELASTIC_PORT=9200
TRANSCRIPT_INDEX=video_text_segments
TEXT_COLLECTION_NAME=video_text_embeddings

# Data paths
DATA_DIR=./data
VIDEOS_DIR=./data/videos
KEYFRAMES_DIR=./data/keyframes
EMBEDDINGS_DIR=./data/embeddings
TRANSCRIPTS_DIR=./data/transcripts
OCR_RESULTS_DIR=./data/ocr_result
CAPTIONS_DIR=./data/captions

# Timing contracts
DEFAULT_FALLBACK_FPS=25.0
KEYFRAME_INTERVAL_SECONDS=1.0

# Visual embedding
# Strong competition profile. Recompute embeddings and recreate Milvus if you change these.
VISUAL_MODEL_PROVIDER=siglip2
VISUAL_MODEL=google/siglip2-so400m-patch16-naflex
VISUAL_MODEL_PRETRAINED=
VECTOR_DIMENSION=1152
VISUAL_TRUNCATE_DIM=1152
MODEL_TRUST_REMOTE_CODE=true

# Query translation: Vietnamese UI query -> English visual query.
ENABLE_QUERY_TRANSLATION=true
QUERY_TRANSLATION_PROVIDER=nllb
QUERY_TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
QUERY_TRANSLATION_SRC_LANG=vie_Latn
QUERY_TRANSLATION_TGT_LANG=eng_Latn
QUERY_TRANSLATION_MAX_LENGTH=128

# Text/OCR/ASR/rerank
ENABLE_DENSE_TEXT_RETRIEVAL=true
TEXT_MODEL_PROVIDER=sentence_transformers
TEXT_MODEL=BAAI/bge-m3
TEXT_VECTOR_DIMENSION=1024
OCR_ENGINE=paddleocr
OCR_LANGUAGES=en,vi
ASR_MODEL=large-v3
ASR_LANGUAGE=vi
RERANK_MODEL_PROVIDER=sentence_transformers
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval
VISUAL_MAX_RESULTS=500
TEXT_MAX_RESULTS=500
TEXT_DENSE_MAX_RESULTS=300
FINAL_MAX_RESULTS=500
RERANK_TOP_K=50
RRF_K=60
WEIGHT_VISUAL=1.0
WEIGHT_TRANSCRIPT=1.0
WEIGHT_OCR=1.0
WEIGHT_CAPTION=0.8
WEIGHT_TEXT_DENSE=0.9

# Evaluation server
EVAL_SERVER_URL=http://192.168.20.156:5601
SESSION_ID=
EVALUATION_ID=
EVAL_USERNAME=team006
EVAL_PASSWORD=123456
