# Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
ELASTIC_HOST=localhost
ELASTIC_PORT=9200
TRANSCRIPT_INDEX=video_text_segments

# Data paths
DATA_DIR=./data
VIDEOS_DIR=./data/videos
KEYFRAMES_DIR=./data/keyframes
EMBEDDINGS_DIR=./data/embeddings
TRANSCRIPTS_DIR=./data/transcripts
OCR_RESULTS_DIR=./data/ocr_result
CAPTIONS_DIR=./data/captions

# Visual embedding
# openclip keeps the current baseline running.
# For SigLIP2/jina-clip-v2, set VISUAL_MODEL_PROVIDER=transformers and update VECTOR_DIMENSION.
VISUAL_MODEL_PROVIDER=openclip
VISUAL_MODEL=ViT-B-32
VISUAL_MODEL_PRETRAINED=openai
VECTOR_DIMENSION=512
MODEL_TRUST_REMOTE_CODE=false

# Text/OCR/ASR/rerank
TEXT_MODEL_PROVIDER=none
TEXT_MODEL=BAAI/bge-m3
OCR_ENGINE=paddleocr
OCR_LANGUAGES=en,vi
ASR_MODEL=large-v3
RERANK_MODEL_PROVIDER=none
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval
VISUAL_MAX_RESULTS=500
TEXT_MAX_RESULTS=500
FINAL_MAX_RESULTS=500
RERANK_TOP_K=50
RRF_K=60
WEIGHT_VISUAL=1.0
WEIGHT_TRANSCRIPT=1.0
WEIGHT_OCR=1.0
WEIGHT_CAPTION=0.8

# Evaluation server
EVAL_SERVER_URL=http://192.168.20.156:5601
SESSION_ID=
EVALUATION_ID=
EVAL_USERNAME=team006
EVAL_PASSWORD=123456

